# backend/.env.example — COMMIT THIS FILE (placeholders only, no real secrets).
# Copy to backend/.env (gitignored by the root .gitignore) and fill in real values.

# ---- MongoDB ----
MONGO_URI=mongodb://localhost:27017
MONGO_DB=nirvana

# ---- Seeding ----
# If true, upsert the 16 plans from data/plans.json into Mongo on startup (idempotent).
# Otherwise run explicitly:  python -m app.seed
SEED_ON_STARTUP=false

# ---- CORS (comma-separated; add your prod origin in prod — exact scheme+host+port, no trailing slash) ----
CORS_ORIGINS=http://localhost:3000,http://localhost:3100

# ---- Slot grid (Asia/Kolkata is authoritative; India has no DST) ----
BOOKING_TIMEZONE=Asia/Kolkata
SLOT_OPEN_HOUR=10
SLOT_CLOSE_HOUR=18
SLOT_DAYS_AHEAD=14

# ---- Email (admin booking notification). Leave SMTP_HOST empty for dev: the mailer logs instead of sending. ----
SMTP_HOST=
# Port 587 => STARTTLS (set SMTP_USE_TLS=true). Port 465 => implicit TLS (auto-detected).
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=Nirvana Bookings <no-reply@nirvana.local>
# Company/admin inbox that receives booking notifications.
# REQUIRED when SMTP_HOST is set — the app refuses to start otherwise.
ADMIN_EMAIL=

# ---- Uvicorn bind ----
API_HOST=0.0.0.0
API_PORT=8000

# Gmail example (real values go in .env ONLY, never committed):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USERNAME=your-account@gmail.com
#   SMTP_PASSWORD=<16-char Gmail App Password>   # NOT your account password
#   ADMIN_EMAIL=your-account@gmail.com
